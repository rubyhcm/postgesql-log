flowchart TD
    App(["Ứng dụng (app_user)"])

    BT[("Bảng nghiệp vụ\norders · products")]

    AT["① func_audit_trigger()\nAFTER ROW · SECURITY DEFINER\nsession_user + OLD/NEW → JSONB"]

    HC["② func_audit_hash_chain()\nBEFORE INSERT\nSHA-256(prev_hash ‖ payload)"]

    AL[("③ audit_logs\nJSONB · Partitioned by Month\nappend-only · GIN Index")]

    WT["④ func_prevent_audit_change()\nBEFORE UPDATE/DELETE — WORM\nRAISE EXCEPTION"]

    SA[("⑤ security_alerts\nautonomous commit via dblink")]

    DDL_LOG[("⑥ audit_ddl_logs\nEvent Trigger ON ddl_command_end\nCREATE / ALTER schema")]

    SIEM[/"Monitoring / SIEM\n(Splunk · ELK · Grafana)"/]

    App -->|"INSERT / UPDATE / DELETE"| BT
    BT -->|"AFTER ROW trigger"| AT
    AT -->|"INSERT log (same transaction)"| HC
    HC --> AL
    AL -.->|"BEFORE UPDATE/DELETE — BỊ CHẶN"| WT
    WT -->|"dblink autonomous INSERT"| SA
    RB(["Rollback Transaction"])
    WT -.->|"RAISE EXCEPTION"| RB
    BT -->|"DDL: CREATE/ALTER"| DDL_LOG
    AL -->|"log shipper"| SIEM

    style App fill:#fff3cd,stroke:#f0ad4e,color:#000
