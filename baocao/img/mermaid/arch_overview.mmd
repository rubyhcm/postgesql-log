    style SA fill:#fce8e6,stroke:#ea4335
    style RB fill:#fce8e6,stroke:#ea4335
    style DDL_LOG fill:#e6f4ea,stroke:#34a853
    style SIEM fill:#f8f9fa,stroke:#aaa,stroke-dasharray:5 5
